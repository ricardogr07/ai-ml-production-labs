resource_group_name = "rg-ai-ml-production-labs-dev"
location            = "eastus"
container_image     = "ghcr.io/<github-username>/llamaindex-doc-qa-lab:latest"
environment_name    = "cae-ai-ml-production-labs-dev"
ghcr_username       = "<github-username>"
ghcr_pat            = "<github-pat-with-read-packages>"
llm_provider        = "ollama"
ollama_model        = "llama3.2"
anthropic_model     = "claude-opus-4-8"
anthropic_api_key   = "<anthropic-api-key>"
ollama_dns_label    = "ollama-lab09-dev"
qdrant_dns_label    = "qdrant-lab09-dev"
qdrant_api_key      = "<random-per-run-key-for-the-deployed-qdrant>"
dockerhub_username  = "<docker-hub-username>"
dockerhub_token     = "<docker-hub-read-access-token>"
