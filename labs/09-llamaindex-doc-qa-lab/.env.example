LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=

QDRANT_URL=http://localhost:6333
# Local docker-compose Qdrant is loopback and needs no key; set this only when
# pointing at an API-key-protected Qdrant (e.g. the deployed Azure instance).
QDRANT_API_KEY=
QDRANT_COLLECTION=wikipedia-docs
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
